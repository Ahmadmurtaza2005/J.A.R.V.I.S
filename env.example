# Copy to ".env" next to jarvis.py. Never commit real secrets.

# Microphone: index from printed list (0, 1, 2...)
JARVIS_MIC_INDEX=

# Or match part of device name from that list (e.g. Realtek, USB, Headset)
JARVIS_MIC_PREF=

# 1/true = skip auto mic pick — use OS default audio input only
JARVIS_USE_DEFAULT_MIC=

# Quieter voices: try 0.28 (more sensitive). Too much noise? try 0.55
JARVIS_ENERGY_RATIO=0.38

# Lowest mic threshold floor (speech_recognition tuning)
JARVIS_ENERGY_FLOOR=38

# 1/true = skip ambient calibration (quiet room; can help sensitivity)
JARVIS_SKIP_AMBIENT=

JARVIS_PAUSE_SEC=0.45
JARVIS_WAIT_SEC=22
JARVIS_PHRASE_SEC=18
JARVIS_AMBIENT_SEC=0.55

# Optional NewsAPI key: https://newsapi.org/register (else BBC RSS is used).
NEWSAPI_KEY=
